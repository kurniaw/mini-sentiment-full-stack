{
  "family": "sentiment-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",

  "executionRoleArn": "arn:aws:iam::548536038171:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::548536038171:role/sentiment-task-role",

  "containerDefinitions": [
    {
      "name": "backend",
      "image": "548536038171.dkr.ecr.ap-southeast-1.amazonaws.com/sentiment-backend:latest",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 3001,
          "protocol": "tcp"
        }
      ],

      "environment": [
        { "name": "PORT",         "value": "3001" },
        { "name": "FRONTEND_URL", "value": "*" }
      ],

      "secrets": [
        {
          "name": "MONGODB_URI",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:548536038171:secret:sentiment/mongodb-uri-oMGu5j"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/sentiment-backend-v2",
          "awslogs-region":        "ap-southeast-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group":  "true"
        }
      },

      "healthCheck": {
        "command":     ["CMD-SHELL", "wget -qO- http://localhost:3001/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 60
      }
    }
  ]
}