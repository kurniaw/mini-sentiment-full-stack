{
  "family": "sentiment-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",

  "executionRoleArn": "arn:aws:iam::548536038171:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::548536038171:role/sentiment-task-role",

  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "548536038171.dkr.ecr.ap-southeast-1.amazonaws.com/sentiment-frontend:latest",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
